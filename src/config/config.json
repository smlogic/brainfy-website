{
  "site": {
    "title": "Brainfy",
    "base_url": "https://brainfy.eu",
    "base_path": "/",
    "trailing_slash": false,
    "favicon": "/images/favicon.png",
    "logo": "/images/logo.png",
    "logo_darkmode": "/images/logo-darkmode.png",
    "logo_width": "150",
    "logo_height": "30",
    "logo_text": "Brainfy"
  },

  "settings": {
    "search": true,
    "sticky_header": true,
    "theme_switcher": true,
    "default_theme": "system",
    "pagination": 2,
    "summary_length": 200,
    "blog_folder": "blog",
    "default_language": "en",
    "disable_languages": [],
    "default_language_in_subdir": false
  },

  "announcement": {
    "enable": true,
    "expire_days": 7
  },

  "params": {
    "contact_form_action": "#",
    "copyright": "Designed And Developed by [Brainfy](https://brainfy.eu)"
  },

  "navigation_button": {
    "enable": false,
    "label": "Github",
    "link": "https://github.com/zeon-studio/astroplate/tree/multilingual"
  },

  "google_tag_manager": {
    "enable": false,
    "gtm_id": "GTM-XXXXXX"
  },

  "disqus": {
    "enable": true,
    "shortname": "themefisher-template",
    "settings": {}
  },

  "metadata": {
    "meta_author": "Brainfy",
    "meta_image": "/images/og-image.png",
    "meta_description": "Projektowanie i integracja systemów Automatyki Przemysłowej (AKPiA), PLC i BMS. Predykcyjne utrzymanie ruchu, bezpieczny zdalny serwis i audyty maszyn."
  }
}